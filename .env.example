APP_ENV=local

# Frontend public variables.
# Values prefixed with NEXT_PUBLIC_ can be exposed to the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend Supabase variables.
# Never expose service role, database URL or JWT secret to the frontend.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_STORAGE_BUCKET_DOCUMENTS=mercadoia-documents
SUPABASE_STORAGE_BUCKET_TEMPLATES=mercadoia-templates
SUPABASE_STORAGE_BUCKET_ARTIFACTS=mercadoia-artifacts
SUPABASE_SIGNED_URL_TTL_SECONDS=300

# Optional local development services.
REDIS_URL=redis://localhost:6379/0
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=minio_password
STORAGE_BUCKET=mercadoia-local

# Providers and runtime settings.
OCR_PROVIDER=fake
LLM_PROVIDER=fake
MAX_FILE_SIZE_MB=25
DEFAULT_RETENTION_DAYS=180
LOG_LEVEL=debug
