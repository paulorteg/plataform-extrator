{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mercadoia.local/schemas/canonical_schema_v1.json",
  "title": "Canonical Schema V1",
  "type": "object",
  "required": [
    "schema_version",
    "case_id",
    "organization_id",
    "source_documents",
    "occurrences",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "case_id": {
      "type": "string",
      "format": "uuid"
    },
    "organization_id": {
      "type": "string",
      "format": "uuid"
    },
    "source_documents": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "occurrences": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/occurrence"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "field": {
      "type": "object",
      "required": [
        "value",
        "status",
        "confidence",
        "evidence_id"
      ],
      "properties": {
        "value": {},
        "value_raw": {},
        "status": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        }
      }
    },
    "occurrence": {
      "type": "object",
      "required": [
        "occurrence_id",
        "organization_id",
        "source_document_id",
        "boletim",
        "evento",
        "locais",
        "envolvidos",
        "empresas",
        "veiculos",
        "cargas",
        "evidencias",
        "validation_issues"
      ],
      "properties": {
        "occurrence_id": {
          "type": "string",
          "format": "uuid"
        },
        "organization_id": {
          "type": "string",
          "format": "uuid"
        },
        "source_document_id": {
          "type": "string",
          "format": "uuid"
        },
        "boletim": {
          "type": "object"
        },
        "evento": {
          "type": "object"
        },
        "locais": {
          "type": "array"
        },
        "envolvidos": {
          "type": "array"
        },
        "empresas": {
          "type": "array"
        },
        "veiculos": {
          "type": "array"
        },
        "cargas": {
          "type": "array"
        },
        "evidencias": {
          "type": "array"
        },
        "validation_issues": {
          "type": "array"
        }
      }
    }
  }
}
